{
  "version": 2,
  "public": false,
  "buildCommand": "node build.js",
  "outputDirectory": ".",
  "cleanUrls": true,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
